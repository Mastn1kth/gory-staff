DATABASE_URL=postgres://gory:gory@localhost:5432/gory_staff
PORT=4000
HOST=127.0.0.1
JWT_SECRET=change-me-before-production
GUEST_JWT_SECRET=change-me-before-production-too
PUBLIC_SERVER_URL=http://localhost:4000
SEED_DEMO_DATA=if-empty
TRUST_PROXY=loopback
TRUSTED_PROXY_IPS=
LOGIN_RATE_LIMIT_WINDOW_MS=300000
LOGIN_RATE_LIMIT_MAX=20
GUEST_MARKETING_PUSH_INTERVAL_MS=86400000
GUEST_MARKETING_PUSH_LIMIT=500
GUEST_MARKETING_PUSH_START_DELAY_MS=60000
DISABLE_GUEST_MARKETING_PUSH=0

# ============================================================================
# ОПТИМИЗАЦИИ ПРОИЗВОДИТЕЛЬНОСТИ
# ============================================================================

# PostgreSQL Connection Pool
PG_POOL_MAX=20
PG_POOL_MIN=2
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECT_TIMEOUT_MS=5000

# ============================================================================
# IIKO ИНТЕГРАЦИЯ
# ============================================================================

IIKO_ENABLED=false
IIKO_API_BASE=https://api-ru.iiko.services
IIKO_API_LOGIN=
IIKO_ORGANIZATION_ID=
IIKO_TERMINAL_GROUP_ID=
IIKO_ORDER_SYNC_ENABLED=true
IIKO_ORDER_STATUS_SYNC_ENABLED=true
# Увеличен интервал с 60 до 120 секунд для снижения нагрузки
IIKO_ORDER_STATUS_SYNC_INTERVAL_SECONDS=120
IIKO_ORDER_STATUS_SYNC_LIMIT=50
IIKO_SOURCE_KEY=gory-staff
IIKO_SERVICE_PRINT=true
IIKO_CHECK_STOP_LIST=true
IIKO_TRANSPORT_TIMEOUT_SECONDS=15
IIKO_WEBHOOK_SECRET=

# iiko Staff Sync - Автоматическая синхронизация персонала
# Включить/выключить автоматическую синхронизацию персонала (по умолчанию: true если IIKO_ENABLED=true)
IIKO_STAFF_SYNC_ENABLED=true
# Интервал синхронизации в секундах (по умолчанию: 3600 = 1 час, минимум: 1800 = 30 минут)
IIKO_STAFF_SYNC_INTERVAL_SECONDS=3600
# Запускать синхронизацию при старте сервера (по умолчанию: true)
IIKO_STAFF_SYNC_ON_STARTUP=true

# Twilio для автоматических напоминаний о бронях
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_STATUS_CALLBACK_URL=
RESERVATION_REMINDER_CHECK_INTERVAL_MS=60000

# Guest news social import. Without these keys /social/import/run returns disabled sources.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
VK_ACCESS_TOKEN=
VK_GROUP_ID=
VK_SEARCH_QUERY=

# ============================================================================
# OAUTH ДЛЯ ВХОДА ГОСТЕЙ
# ============================================================================

# Яндекс OAuth
# Получить на https://oauth.yandex.ru/
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# ВКонтакте OAuth
# Получить на https://vk.com/apps?act=manage
VK_CLIENT_ID=
VK_CLIENT_SECRET=
